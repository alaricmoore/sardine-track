# Patient config - contains location coordinates and baseline values
config.json

# The database itself - contains all health data
*.db
*.sqlite
*.sqlite3
*.csv

# Apple Health exports - sensitive health data
Export.xml
apple_health_export/
*.zip
*.numbers


# ============================================================
# Python
# ============================================================

# Virtual environment
.venv/
venv/
env/

# Compiled Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# Distribution / packaging
build/
dist/
*.egg-info/
.eggs/

# pytest
.pytest_cache/
.coverage
htmlcov/

# mypy
.mypy_cache/

# ============================================================
# Environment and secrets
# ============================================================

.env
.env.local
.env.*.local

# ============================================================
