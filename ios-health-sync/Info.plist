<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>NSHealthShareUsageDescription</key>
    <string>Health Sync reads your health data to send it to your personal biotracker for flare pattern analysis. Data goes only to your private server.</string>
    <key>NSHealthUpdateUsageDescription</key>
    <string>This app does not write to Apple Health.</string>
    <key>BGTaskSchedulerPermittedIdentifiers</key>
    <array>
        <string>com.biotracking.healthsync.daily</string>
    </array>
    <key>UIBackgroundModes</key>
    <array>
        <string>fetch</string>
        <string>processing</string>
    </array>
</dict>
</plist>
